# Copy this file to `.env` and adjust as needed.
# The defaults target the public Sauce Labs demo site, so no secrets are required.

# Base URL of the system under test.
BASE_URL=https://www.saucedemo.com

# Credentials for the Sauce Labs demo app.
# All demo accounts share the same password: secret_sauce
STANDARD_USER=standard_user
STANDARD_PASSWORD=secret_sauce

# A user that is locked out and should surface an error on login.
LOCKED_OUT_USER=locked_out_user
