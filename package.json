{
  "name": "playwright-e2e-framework",
  "version": "1.0.0",
  "description": "Professional Playwright + TypeScript end-to-end test automation framework using the Page Object Model and custom fixtures, exercised against the Sauce Labs demo app.",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "report": "playwright show-report",
    "install:browsers": "playwright install"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "test-automation",
    "page-object-model",
    "sdet",
    "qa"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22",
    "dotenv": "^16",
    "typescript": "^5.6.0"
  }
}
